# ============================================
# Monitoring & Error Tracking
# ============================================
SENTRY_DSN=
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
