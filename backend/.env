SATU_SEHAT_CLIENT_SECRET=your_client_secret
SATU_SEHAT_ORG_ID=your_org_id
SATU_SEHAT_ENV=production

# ============================================
# File Storage
# ============================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# Or use S3-compatible storage:
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
