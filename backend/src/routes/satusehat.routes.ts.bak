// AUTHENTICATION
// ============================================

/**
 * GET /api/satusehat/token
 * Get or refresh access token
 */
router.get('/token', asyncHandler(async (req: Request, res: Response) => {
  const token = await satusehatService.getAccessToken();

  res.json({
    success: true,
    data: {
      access_token: token,
      expires_in: 3600
    }
  });
}));

