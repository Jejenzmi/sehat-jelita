# ============================================
# SIMRS ZEN - Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/simrs_zen?schema=public

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis (for session/cache)
REDIS_URL=redis://localhost:6379

# ============================================
# BPJS Integration
# ============================================
BPJS_CONS_ID=your_cons_id
BPJS_SECRET_KEY=your_secret_key
BPJS_USER_KEY=your_user_key
BPJS_BASE_URL=https://apijkn-dev.bpjs-kesehatan.go.id
BPJS_SERVICE_NAME=JKN

# V-Claim specific
BPJS_VCLAIM_URL=https://apijkn-dev.bpjs-kesehatan.go.id/vclaim-rest-dev
BPJS_APLICARE_URL=https://apijkn-dev.bpjs-kesehatan.go.id/aplicaresws

# ============================================
# SATU SEHAT Integration
# ============================================
SATUSEHAT_AUTH_URL=https://api-satusehat-stg.dto.kemkes.go.id/oauth2/v1
SATUSEHAT_BASE_URL=https://api-satusehat-stg.dto.kemkes.go.id/fhir-r4/v1
SATUSEHAT_CLIENT_ID=your_client_id
SATUSEHAT_CLIENT_SECRET=your_client_secret
SATUSEHAT_ORGANIZATION_ID=your_org_id
# Also used directly by the service:
SATU_SEHAT_CLIENT_ID=your_client_id
SATU_SEHAT_CLIENT_SECRET=your_client_secret
SATU_SEHAT_ORG_ID=your_org_id
SATU_SEHAT_ENV=sandbox

# ============================================
# File Storage
# ============================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# Or use S3-compatible storage:
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SIMRS ZEN <noreply@example.com>

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=dev

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Security / Encryption
# ============================================
# Secret used to derive the AES-256-GCM key for PII field encryption.
# Must be set in production. Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=change-me-in-production-use-at-least-32-chars


# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# ICD-11 WHO API Integration
# Register at: https://icd.who.int/icdapi/Account/Register
# ============================================
ICD11_CLIENT_ID=your_icd11_client_id
ICD11_CLIENT_SECRET=your_icd11_client_secret
ICD11_TOKEN_URL=https://icdaccessmanagement.who.int/connect/token
ICD11_BASE_URL=https://id.who.int
ICD11_LINEARIZATION=mms
ICD11_RELEASE=2024-01

# ============================================
# WhatsApp Notifications (Fonnte — Indonesia)
# Register at: https://fonnte.com
# ============================================
FONNTE_TOKEN=your_fonnte_token

# ============================================
# SMS Notifications (Twilio)
# Register at: https://twilio.com
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ============================================
# WebRTC TURN Server (for Telemedicine)
# Self-host coturn or use Metered.ca / Twilio TURN
# Option A — HMAC time-limited credentials (recommended):
# ============================================
TURN_HOST=turn.yourhospital.com
TURN_SECRET=your_hmac_secret_at_least_32_chars
# Option B — static credentials (less secure):
# TURN_USERNAME=simrs
# TURN_PASSWORD=your_turn_password

# ============================================
# LIS Gateway (Lab Analyzer Interface)
# Enable only if connected to physical lab analyzers
# ============================================
LIS_GATEWAY_ENABLED=false
LIS_ASTM_PORT=9001
LIS_HL7_PORT=9002

# ============================================
# Observability
# ============================================
# Sentry error tracking (optional but recommended for production)
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ============================================
# Direct DB URL (for Prisma migrations only)
# Use this when DATABASE_URL points to a pooler (PgBouncer etc.)
# ============================================
DIRECT_URL=postgresql://user:password@localhost:5432/simrs_zen
