// SIMRS ZEN - Prisma Schema
// Database schema matching backend/database/schema.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ============================================
// ENUMS (matching schema.sql)
// ============================================

enum BedStatus {
  available
  occupied
  maintenance
  reserved
}

enum BillingStatus {
  pending
  partial
  paid
  cancelled
  refunded
}

enum PaymentType {
  cash
  bpjs
  insurance
  corporate
  credit_card
  debit_card
}

enum BloodType {
  A_POSITIVE  @map("A+")
  A_NEGATIVE  @map("A-")
  B_POSITIVE  @map("B+")
  B_NEGATIVE  @map("B-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  O_POSITIVE  @map("O+")
  O_NEGATIVE  @map("O-")
}

enum ClaimStatus {
  draft
  submitted
  verified
  approved
  rejected
  paid
}

// ============================================
// AUTH & USERS
// ============================================

model profiles {
  id            String    @id @default(uuid())
  user_id       String    @unique
  email         String    @unique
  full_name     String?
  phone         String?
  avatar_url    String?
  password_hash String?
  is_active     Boolean   @default(true)
  last_login    DateTime?
  reset_token         String?
  reset_token_expires DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  user_roles user_roles[]
  employees  employees[]
  audit_logs audit_logs[]
  chat_messages chat_messages[]
}

model user_roles {
  id          String   @id @default(uuid())
  user_id     String
  role        String
  assigned_at DateTime @default(now())
  assigned_by String?

  profile profiles @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, role])
  @@index([user_id])
}

model menu_access {
  id         String   @id @default(uuid())
  role       String
  menu_path  String
  can_view   Boolean  @default(false)
  can_create Boolean  @default(false)
  can_edit   Boolean  @default(false)
  can_delete Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([role, menu_path])
}

// ============================================
// MASTER DATA
// ============================================

model departments {
  id              String   @id @default(uuid())
  department_code String   @unique
  department_name String
  department_type String?
  head_doctor_id  String?
  phone           String?
  location        String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  doctors      doctors[]
  employees    employees[]
  rooms        rooms[]
  visits       visits[]
  appointments appointments[]
}

model rooms {
  id            String   @id @default(uuid())
  room_number   String
  room_name     String?
  department_id String?
  room_type     String?
  floor         Int?
  capacity      Int      @default(1)
  rate_per_day  Decimal?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  departments departments? @relation(fields: [department_id], references: [id])
  beds        beds[]

  @@index([department_id])
}

model beds {
  id                 String    @id @default(uuid())
  bed_number         String
  room_id            String
  status             BedStatus @default(available)
  current_patient_id String?
  notes              String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  rooms  rooms    @relation(fields: [room_id], references: [id])
  visits visits[]

  @@unique([room_id, bed_number])
  @@index([room_id])
}

model doctors {
  id               String   @id @default(uuid())
  employee_id      String?
  user_id          String?
  doctor_code      String   @unique
  sip_number       String?
  str_number       String?
  full_name        String?
  specialization   String?
  department_id    String?
  consultation_fee Decimal?
  is_active        Boolean  @default(true)
  schedule         Json?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  departments     departments?      @relation(fields: [department_id], references: [id])
  visits          visits[]
  appointments    appointments[]
  prescriptions   prescriptions[]
  medical_records medical_records[]
  lab_orders      lab_orders[]

  @@index([department_id])
}

// ============================================
// PATIENTS
// ============================================

model patients {
  id                         String    @id @default(uuid())
  medical_record_number      String    @unique
  nik                        String?   @unique
  bpjs_number                String?
  full_name                  String
  birth_date                 DateTime?
  birth_place                String?
  gender                     String?
  blood_type                 String?
  religion                   String?
  marital_status             String?
  education                  String?
  occupation                 String?
  address                    String?
  rt                         String?
  rw                         String?
  kelurahan                  String?
  kecamatan                  String?
  city                       String?
  province                   String?
  postal_code                String?
  phone                      String?
  mobile_phone               String?
  email                      String?
  emergency_contact_name     String?
  emergency_contact_phone    String?
  emergency_contact_relation String?
  allergy_notes              String?
  chronic_conditions         String?
  is_active                  Boolean   @default(true)
  photo_url                  String?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  visits                visits[]
  appointments          appointments[]
  billings              billings[]
  medical_records       medical_records[]
  prescriptions         prescriptions[]
  lab_orders            lab_orders[]
  radiology_orders      radiology_orders[]
  transfusion_requests  transfusion_requests[]
  surgeries             surgeries[]
  inpatient_admissions  inpatient_admissions[]
  icu_admissions        icu_admissions[]
  dialysis_schedules    dialysis_schedules[]
  dialysis_sessions     dialysis_sessions[]
  mcu_registrations     mcu_registrations[]
  nutrition_orders      nutrition_orders[]
  nutrition_assessments nutrition_assessments[]
  meal_plans            meal_plans[]
  patient_allergies     patient_allergies[]
  rehabilitation_cases  rehabilitation_cases[]
}

// ============================================
// VISITS & MEDICAL RECORDS
// ============================================

model visits {
  id                      String    @id @default(uuid())
  visit_number            String    @unique
  patient_id              String
  visit_date              DateTime  @default(now())
  visit_type              String
  department_id           String?
  doctor_id               String?
  bed_id                  String?
  admission_date          DateTime?
  discharge_date          DateTime?
  checkin_time            DateTime?
  checkout_time           DateTime?
  chief_complaint         String?
  diagnosis               String?
  icd10_code              String?
  treatment_plan          String?
  discharge_summary       String?
  status                  String    @default("active")
  payment_type            PaymentType?
  bpjs_sep_number         String?
  insurance_policy_number String?
  created_by              String?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  patients         patients     @relation(fields: [patient_id], references: [id])
  doctors          doctors?     @relation(fields: [doctor_id], references: [id])
  departments      departments? @relation(fields: [department_id], references: [id])
  beds             beds?        @relation(fields: [bed_id], references: [id])
  billings         billings[]
  medical_records  medical_records[]
  prescriptions    prescriptions[]
  lab_orders       lab_orders[]
  queue_entries    queue_entries[]
  radiology_orders radiology_orders[]

  @@index([patient_id])
  @@index([visit_date])
  @@index([department_id])
  @@index([doctor_id])
  @@index([bed_id])
}

model medical_records {
  id            String   @id @default(uuid())
  patient_id    String
  visit_id      String?
  record_date   DateTime @default(now())
  record_type   String?
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  vital_signs   Json?
  physical_exam Json?
  doctor_id     String?
  created_by    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  patients patients  @relation(fields: [patient_id], references: [id])
  visits   visits?   @relation(fields: [visit_id], references: [id])
  doctors  doctors?  @relation(fields: [doctor_id], references: [id])

  @@index([patient_id])
  @@index([visit_id])
}

// ============================================
// PHARMACY
// ============================================

model medicines {
  id                    String   @id @default(uuid())
  medicine_code         String   @unique
  medicine_name         String
  generic_name          String?
  category              String?
  form                  String?
  strength              String?
  unit                  String
  manufacturer          String?
  selling_price         Decimal
  purchase_price        Decimal?
  min_stock             Int      @default(10)
  max_stock             Int      @default(1000)
  is_active             Boolean  @default(true)
  requires_prescription Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  medicine_batches medicine_batches[]
}

model medicine_batches {
  id             String   @id @default(uuid())
  medicine_id    String
  batch_number   String
  quantity       Int
  expiry_date    DateTime
  purchase_date  DateTime?
  purchase_price Decimal?
  supplier_id    String?
  location       String?
  status         String   @default("available")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  medicines medicines @relation(fields: [medicine_id], references: [id])

  @@index([medicine_id])
}

model prescriptions {
  id                  String   @id @default(uuid())
  prescription_number String   @unique
  patient_id          String
  visit_id            String?
  doctor_id           String?
  prescription_date   DateTime @default(now())
  status              String   @default("pending")
  notes               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  patients           patients           @relation(fields: [patient_id], references: [id])
  visits             visits?            @relation(fields: [visit_id], references: [id])
  doctors            doctors?           @relation(fields: [doctor_id], references: [id])
  prescription_items prescription_items[]

  @@index([patient_id])
  @@index([visit_id])
}

model prescription_items {
  id              String   @id @default(uuid())
  prescription_id String
  medicine_id     String?
  medicine_name   String
  dosage          String?
  frequency       String?
  duration        String?
  quantity        Int?
  unit            String?
  instructions    String?
  created_at      DateTime @default(now())

  prescriptions prescriptions @relation(fields: [prescription_id], references: [id])

  @@index([prescription_id])
}

// ============================================
// LABORATORY
// ============================================

model lab_orders {
  id           String   @id @default(uuid())
  order_number String   @unique
  patient_id   String
  visit_id     String?
  doctor_id    String?
  order_date   DateTime @default(now())
  priority     String   @default("normal")
  status       String   @default("pending")
  notes        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  patients    patients    @relation(fields: [patient_id], references: [id])
  visits      visits?     @relation(fields: [visit_id], references: [id])
  doctors     doctors?    @relation(fields: [doctor_id], references: [id])
  lab_results lab_results[]

  @@index([patient_id])
  @@index([visit_id])
}

model lab_results {
  id              String    @id @default(uuid())
  order_id        String
  test_code       String
  test_name       String
  result_value    String?
  unit            String?
  reference_range String?
  flag            String?
  performed_by    String?
  verified_by     String?
  result_date     DateTime?
  notes           String?
  created_at      DateTime  @default(now())

  lab_orders lab_orders @relation(fields: [order_id], references: [id])

  @@unique([order_id, test_code])
  @@index([order_id])
}

// ============================================
// BILLING
// ============================================

model billings {
  id             String        @id @default(uuid())
  invoice_number String        @unique
  patient_id     String
  visit_id       String
  billing_date   DateTime      @default(now())
  payment_type   PaymentType
  subtotal       Decimal       @default(0)
  discount       Decimal?
  tax            Decimal?
  total          Decimal       @default(0)
  paid_amount    Decimal?
  status         BillingStatus @default(pending)
  payment_method String?
  payment_date   DateTime?
  paid_by        String?
  notes          String?
  created_by     String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  patients      patients      @relation(fields: [patient_id], references: [id])
  visits        visits        @relation(fields: [visit_id], references: [id])
  billing_items billing_items[]

  @@index([patient_id])
  @@index([visit_id])
}

model billing_items {
  id          String   @id @default(uuid())
  billing_id  String
  item_type   String
  item_name   String
  quantity    Int      @default(1)
  unit_price  Decimal
  total_price Decimal
  notes       String?
  created_at  DateTime @default(now())

  billings billings @relation(fields: [billing_id], references: [id])

  @@index([billing_id])
}

// ============================================
// BPJS
// ============================================

model bpjs_claims {
  id                 String      @id @default(uuid())
  claim_number       String      @unique
  patient_id         String
  visit_id           String
  sep_number         String
  claim_date         DateTime    @default(now())
  claim_amount       Decimal
  approved_amount    Decimal?
  status             ClaimStatus @default(draft)
  inacbg_code        String?
  inacbg_description String?
  submission_date    DateTime?
  verification_date  DateTime?
  rejection_reason   String?
  notes              String?
  created_by         String?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  @@index([patient_id])
  @@index([visit_id])
}

// ============================================
// SUPPLIERS & PURCHASE ORDERS
// ============================================

model suppliers {
  id             String   @id @default(uuid())
  supplier_code  String   @unique
  supplier_name  String
  contact_person String?
  phone          String?
  email          String?
  address        String?
  npwp           String?
  payment_terms  String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  purchase_orders purchase_orders[]
}

model purchase_orders {
  id                String    @id @default(uuid())
  po_number         String    @unique
  supplier_id       String
  order_date        DateTime  @default(now())
  expected_delivery DateTime?
  total_amount      Decimal
  status            String    @default("draft")
  submitted_at      DateTime?
  approved_by       String?
  approved_at       DateTime?
  received_at       DateTime?
  received_by       String?
  notes             String?
  created_by        String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  suppliers            suppliers              @relation(fields: [supplier_id], references: [id])
  purchase_order_items purchase_order_items[]

  @@index([supplier_id])
}

model purchase_order_items {
  id                String   @id @default(uuid())
  purchase_order_id String
  item_id           String
  quantity          Int
  unit_price        Decimal
  subtotal          Decimal
  received_quantity Int?
  created_at        DateTime @default(now())

  purchase_orders purchase_orders @relation(fields: [purchase_order_id], references: [id])

  @@index([purchase_order_id])
}

// ============================================
// HR
// ============================================

model employees {
  id              String    @id @default(uuid())
  user_id         String?
  employee_code   String    @unique
  full_name       String
  nik             String?
  birth_date      DateTime?
  gender          String?
  address         String?
  phone           String?
  email           String?
  department_id   String?
  position        String?
  employment_type String?
  join_date       DateTime?
  resign_date     DateTime?
  salary          Decimal?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  profiles        profiles?    @relation(fields: [user_id], references: [user_id])
  departments     departments? @relation(fields: [department_id], references: [id])
  attendance      attendance[]
  leave_requests  leave_requests[]
  payroll         payroll[]

  @@index([user_id])
  @@index([department_id])
}

model attendance {
  id              String   @id @default(uuid())
  employee_id     String
  attendance_date DateTime @db.Date
  check_in        DateTime?
  check_out       DateTime?
  status          String   @default("present")
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  employees employees @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, attendance_date])
  @@index([employee_id])
}

model leave_requests {
  id             String    @id @default(uuid())
  employee_id    String
  leave_type     String
  start_date     DateTime
  end_date       DateTime
  reason         String?
  status         String    @default("pending")
  approved_by    String?
  approved_at    DateTime?
  approval_notes String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  employees employees @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
}

model payroll {
  id           String    @id @default(uuid())
  employee_id  String
  period_month Int
  period_year  Int
  base_salary  Decimal
  allowances   Decimal   @default(0)
  deductions   Decimal   @default(0)
  overtime     Decimal   @default(0)
  net_salary   Decimal
  status       String    @default("draft")
  paid_at      DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  employees employees @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, period_month, period_year])
  @@index([employee_id])
}

// ============================================
// APPOINTMENTS
// ============================================

model appointments {
  id               String   @id @default(uuid())
  patient_id       String
  doctor_id        String
  department_id    String?
  appointment_date DateTime @db.Date
  appointment_time String
  end_time         String?
  appointment_type String   @default("consultation")
  status           String   @default("scheduled")
  chief_complaint  String?
  notes            String?
  booking_source   String?
  reminder_sent    Boolean  @default(false)
  created_by       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  patients    patients     @relation(fields: [patient_id], references: [id])
  doctors     doctors      @relation(fields: [doctor_id], references: [id])
  departments departments? @relation(fields: [department_id], references: [id])

  @@index([patient_id])
  @@index([doctor_id])
  @@index([appointment_date])
}

// ============================================
// QUEUE MANAGEMENT
// ============================================

model queue_entries {
  id            String    @id @default(uuid())
  visit_id      String
  department_id String
  queue_number  Int
  status        String    @default("waiting")
  called_at     DateTime?
  served_at     DateTime?
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  visits visits @relation(fields: [visit_id], references: [id])

  @@index([department_id])
  @@index([visit_id])
}

// ============================================
// AUDIT & SYSTEM
// ============================================

model audit_logs {
  id         String   @id @default(uuid())
  user_id    String?
  table_name String
  record_id  String?
  action     String
  old_data   Json?
  new_data   Json?
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())

  user profiles? @relation(fields: [user_id], references: [user_id])

  @@index([table_name, created_at])
  @@index([user_id, created_at])
}

model system_settings {
  id            String   @id @default(uuid())
  setting_key   String   @unique
  setting_value String?
  setting_type  String?
  description   String?
  is_public     Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model notifications {
  id             String    @id @default(uuid())
  user_id        String
  title          String
  message        String?
  type           String?
  reference_type String?
  reference_id   String?
  is_read        Boolean   @default(false)
  read_at        DateTime?
  created_at     DateTime  @default(now())

  @@index([user_id])
}

// ============================================
// CHAT
// ============================================

model chat_rooms {
  id           String   @id @default(uuid())
  room_name    String?
  room_type    String   @default("direct")
  created_by   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  chat_messages     chat_messages[]
  chat_participants chat_participants[]
}

model chat_participants {
  id           String    @id @default(uuid())
  room_id      String
  user_id      String
  joined_at    DateTime  @default(now())
  last_read_at DateTime?

  chat_rooms chat_rooms @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@unique([room_id, user_id])
  @@index([room_id])
  @@index([user_id])
}

model chat_messages {
  id           String   @id @default(uuid())
  room_id      String
  sender_id    String
  content      String
  message_type String   @default("text")
  created_at   DateTime @default(now())

  chat_rooms chat_rooms @relation(fields: [room_id], references: [id], onDelete: Cascade)
  profiles   profiles?  @relation(fields: [sender_id], references: [user_id])

  @@index([room_id])
  @@index([sender_id])
}

// ============================================
// RADIOLOGY
// ============================================

model radiology_orders {
  id               String    @id @default(uuid())
  order_number     String    @unique
  patient_id       String
  visit_id         String?
  doctor_id        String?
  examination_type String?
  modality_type    String?
  modality         String?
  body_part        String?
  clinical_info    String?
  priority         String    @default("ROUTINE")
  status           String    @default("ORDERED")
  ordered_by       String?
  technician_id    String?
  room_number      String?
  examination_start DateTime?
  examination_end   DateTime?
  image_urls       String[]
  radiation_dose   String?
  technique_used   String?
  order_date       DateTime  @default(now())
  notes            String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  patients         patients           @relation(fields: [patient_id], references: [id])
  visits           visits?            @relation(fields: [visit_id], references: [id])
  radiology_results radiology_results[]

  @@index([patient_id])
  @@index([visit_id])
}

model radiology_results {
  id              String    @id @default(uuid())
  order_id        String
  findings        String?
  impression      String?
  recommendations String?
  radiologist_id  String?
  report_date     DateTime?
  verified_at     DateTime?
  image_urls      String[]
  created_at      DateTime  @default(now())

  radiology_orders radiology_orders @relation(fields: [order_id], references: [id])

  @@index([order_id])
}

// ============================================
// BLOOD BANK
// ============================================

model blood_inventory {
  id                      String    @id @default(uuid())
  bag_number              String    @unique
  blood_type              String
  product_type            String
  volume                  Int?
  collection_date         DateTime
  expiry_date             DateTime
  donor_id                String?
  status                  String    @default("available")
  storage_location        String?
  screening_date          DateTime?
  hiv_status              String?
  hbsag_status            String?
  hcv_status              String?
  vdrl_status             String?
  malaria_status          String?
  screened_by             String?
  reserved_for_patient_id String?
  issued_date             DateTime?
  issued_by               String?
  issued_to_department    String?
  source_blood_bank       String?
  notes                   String?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  crossmatch_tests    crossmatch_tests[]
  transfusion_records transfusion_records[]

  @@index([blood_type])
  @@index([status])
}

model transfusion_requests {
  id                    String    @id @default(uuid())
  request_number        String    @unique
  patient_id            String
  visit_id              String?
  requesting_doctor_id  String?
  blood_type            String?
  blood_type_requested  String?
  product_type          String
