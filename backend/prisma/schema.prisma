model death_certificates {
  id                       String    @id @default(uuid())
  certificate_number       String    @unique
  case_id                  String
  patient_id               String?
  death_date               DateTime
  death_time               String?
  place_of_death           String?
  cause_of_death_1a        String?
  cause_of_death_1b        String?
  cause_of_death_1c        String?
  contributing_conditions  String?
  manner_of_death          String?
  certifying_doctor_id     String?
  certifying_doctor_name   String?
  certificate_date         DateTime  @default(now())
  issued_to                String?
  status                   String    @default("draft")
  notes                    String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  mortuary_cases mortuary_cases @relation(fields: [case_id], references: [id])

  @@index([case_id])
}

model visum_reports {
  id                    String    @id @default(uuid())
  visum_number          String    @unique
  patient_id            String?
  visum_type            String?
  police_request_number String?
  police_request_date   DateTime?
  requesting_unit       String?
  case_description      String?
  examination_date      DateTime?
  physical_findings     String?
  injuries              Json?
  conclusions           String?
  opinion               String?
  status                String    @default("draft")
  examining_doctor_id   String?
  notes                 String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  patients patients? @relation(fields: [patient_id], references: [id])

  @@index([status])
}

// ============================================
// EDUCATION (TEACHING HOSPITAL)
// ============================================

model medical_trainees {
  id                    String    @id @default(uuid())
  trainee_code          String    @unique
  full_name             String
  trainee_type          String?
  institution           String?
  program               String?
  start_date            DateTime?
  end_date              DateTime?
  primary_supervisor_id String?
  email                 String?
  phone                 String?
  address               String?
  status                String    @default("active")
  notes                 String?
  created_by            String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  clinical_rotations    clinical_rotations[]
  activity_registrations activity_registrations[]
}

model clinical_rotations {
  id                String    @id @default(uuid())
  trainee_id        String
  department_id     String?
  supervisor_id     String?
  start_date        DateTime
  end_date          DateTime?
  rotation_type     String?
  objectives        String?
  performance_score Decimal?
  evaluation_notes  String?
  status            String    @default("scheduled")
  notes             String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  medical_trainees medical_trainees @relation(fields: [trainee_id], references: [id])

  @@index([trainee_id])
}

model academic_activities {
  id                String    @id @default(uuid())
  activity_code     String    @unique
  activity_type     String?
  title             String
  description       String?
  activity_date     DateTime?
  start_time        String?
  end_time          String?
  location          String?
  department_id     String?
  speaker_names     String?
  max_participants  Int?
  registered_count  Int       @default(0)
  skp_points        Decimal?
  status            String    @default("scheduled")
  notes             String?
  organizer_id      String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  activity_registrations activity_registrations[]
}

model activity_registrations {
  id                String    @id @default(uuid())
  activity_id       String
  trainee_id        String?
  employee_id       String?
  registration_date DateTime  @default(now())
  attendance_status String    @default("registered")
  certificate_issued Boolean  @default(false)
  notes             String?
  created_at        DateTime  @default(now())

  academic_activities academic_activities @relation(fields: [activity_id], references: [id])
  medical_trainees    medical_trainees?   @relation(fields: [trainee_id], references: [id])

  @@index([activity_id])
}

model research_projects {
  id                      String    @id @default(uuid())
  project_code            String    @unique
  title                   String
  principal_investigator  String?
  co_investigators        Json?
  department_id           String?
  start_date              DateTime?
  end_date                DateTime?
  funding_source          String?
  budget                  Decimal?
  ethics_approval_number  String?
  ethics_approval_date    DateTime?
  abstract                String?
  status                  String    @default("proposed")
  publication_title       String?
  publication_date        DateTime?
  notes                   String?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
}

// ============================================
// HR (SUPPLEMENTAL)
// ============================================

model trainings {
  id             String    @id @default(uuid())
  training_code  String?   @unique
  training_name  String
  training_type  String?
  provider       String?
  start_date     DateTime?
  end_date       DateTime?
  location       String?
  max_participants Int?
  cost           Decimal?
  description    String?
  status         String    @default("planned")
  created_by     String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
}
