// SIMRS ZEN - Prisma Schema
// Database schema matching backend/database/schema.sql

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

// ============================================
// HOSPITALS (for setup wizard)

model hospitals {
  id         String   @id @default(uuid())
  name       String
  address    String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ============================================
// ENUMS (matching schema.sql)
// ============================================

enum BedStatus {
  available
  occupied
  maintenance
  reserved
}

enum BillingStatus {
  pending
  partial
  paid
  cancelled
  refunded
}

enum PaymentType {
  cash
  bpjs
  insurance
  corporate
  credit_card
  debit_card
}

enum BloodType {
  A_POSITIVE  @map("A+")
  A_NEGATIVE  @map("A-")
  B_POSITIVE  @map("B+")
  B_NEGATIVE  @map("B-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  O_POSITIVE  @map("O+")
  O_NEGATIVE  @map("O-")
}

enum ClaimStatus {
  draft
  submitted
  verified
  approved
  rejected
  paid
}

enum BloodProductType {
  whole_blood
  packed_red_cells
  fresh_frozen_plasma
  platelets
  cryoprecipitate
}

enum BloodStatus {
  available
  reserved
  issued
  expired
  discarded
  quarantine
}

enum CrossmatchResult {
  compatible
  incompatible
  pending
}

// ============================================
// AUTH & USERS
// ============================================

model profiles {
  id            String    @id @default(uuid())
  user_id       String    @unique
  email         String    @unique
  full_name     String?
  phone         String?
  avatar_url    String?
  password_hash String?
  is_active     Boolean   @default(true)
  last_login    DateTime?
  reset_token         String?
  reset_token_expires DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  user_roles user_roles[]
  employees  employees[]
  audit_logs audit_logs[]
  chat_messages chat_messages[]
}

model user_roles {
  id          String   @id @default(uuid())
  user_id     String
  role        String
  assigned_at DateTime @default(now())
  assigned_by String?

  profile profiles @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, role])
  @@index([user_id])
}

model menu_access {
  id         String   @id @default(uuid())
  role       String
  menu_path  String
  can_view   Boolean  @default(false)
  can_create Boolean  @default(false)
  can_edit   Boolean  @default(false)
  can_delete Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([role, menu_path], name: "role_menu_path")
}

// ============================================
// MASTER DATA
// ============================================

model departments {
  id              String   @id @default(uuid())
  department_code String   @unique
  department_name String
  department_type String?
  head_doctor_id  String?
  phone           String?
  location        String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  doctors       doctors[]
  employees     employees[]
  rooms         rooms[]
  visits        visits[]
  appointments  appointments[]
  billing_rules           billing_rules[]
  analytics_snapshots     analytics_snapshots[]
  aspak_assets            aspak_assets[]
  patient_incidents       patient_incidents[]
  analytics_snapshots analytics_snapshots[]
  doctor_schedules    doctor_schedules[]
  work_shifts      work_shifts[]
}

model rooms {
  id            String   @id @default(uuid())
  room_number   String
  room_name     String?
  department_id String?
  room_type     String?
  floor         Int?
  capacity      Int      @default(1)
  rate_per_day  Decimal?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  departments departments? @relation(fields: [department_id], references: [id])
  beds        beds[]

  @@index([department_id])
}

model beds {
  id                 String    @id @default(uuid())
  bed_number         String
  room_id            String
  status             BedStatus @default(available)
  current_patient_id String?
  notes              String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  rooms  rooms    @relation(fields: [room_id], references: [id])
  visits visits[]

  @@unique([room_id, bed_number])
  @@index([room_id])
}

model doctors {
  id               String   @id @default(uuid())
  employee_id      String?
  user_id          String?
  doctor_code      String   @unique
  sip_number       String?
  str_number       String?
  full_name        String?
  specialization   String?
  department_id    String?
  consultation_fee Decimal?
  is_active        Boolean  @default(true)
  schedule         Json?
  satusehat_id     String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  departments     departments?      @relation(fields: [department_id], references: [id])
  visits          visits[]
  appointments    appointments[]
  prescriptions   prescriptions[]
  medical_records medical_records[]
  lab_orders      lab_orders[]
  doctor_schedules doctor_schedules[]
  telemedicine_sessions telemedicine_sessions[]

  @@index([department_id])
}

// ============================================
// PATIENTS
// ============================================

model patients {
  id                         String    @id @default(uuid())
  medical_record_number      String    @unique
  nik                        String?   @unique  // stored encrypted
  bpjs_number                String?            // stored encrypted
  full_name                  String
  birth_date                 DateTime?
  birth_place                String?
  gender                     String?
  // PII search hashes (SHA-256, non-reversible)
  nik_hash                   String?
  bpjs_number_hash           String?
  mobile_phone_hash          String?
  email_hash                 String?
  blood_type                 String?
  religion                   String?
  marital_status             String?
  education                  String?
  occupation                 String?
  address                    String?
  rt                         String?
  rw                         String?
  kelurahan                  String?
  kecamatan                  String?
  city                       String?
  province                   String?
  postal_code                String?
  phone                      String?
  mobile_phone               String?
  email                      String?
  emergency_contact_name     String?
  emergency_contact_phone    String?
  emergency_contact_relation String?
  allergy_notes              String?
  chronic_conditions         String?
  is_active                  Boolean   @default(true)
  photo_url                  String?
  satusehat_id               String?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  visits          visits[]
  appointments    appointments[]
  billings        billings[]
  medical_records medical_records[]
  prescriptions   prescriptions[]
  lab_orders      lab_orders[]
  radiology_orders     radiology_orders[]
  surgeries            surgeries[]
  transfusion_requests transfusion_requests[]
  crossmatch_tests     crossmatch_tests[]
  inpatient_admissions inpatient_admissions[]
  emergency_visits     emergency_visits[]
  icu_admissions       icu_admissions[]
  dialysis_schedules   dialysis_schedules[]
  mcu_registrations    mcu_registrations[]
  nutrition_assessments nutrition_assessments[]
  patient_allergies     patient_allergies[]
  nutrition_orders      nutrition_orders[]
  meal_plans            meal_plans[]
  rehabilitation_cases  rehabilitation_cases[]
  mortuary_cases        mortuary_cases[]
  visum_reports         visum_reports[]
  home_care_visits      home_care_visits[]
  telemedicine_sessions telemedicine_sessions[]
  sisrute_referrals     sisrute_referrals[]
  dicom_studies         dicom_studies[]
  dicom_worklist           dicom_worklist[]
  patient_drug_allergies   patient_drug_allergies[]
  patient_incidents        patient_incidents[]
  patient_consents         patient_consents[]
  notification_channels    notification_channels[]
  vital_signs              vital_signs[]
}

// ============================================
// VISITS & MEDICAL RECORDS
// ============================================

model visits {
  id                      String    @id @default(uuid())
  visit_number            String    @unique
  patient_id              String
  visit_date              DateTime  @default(now())
  visit_type              String
  department_id           String?
  doctor_id               String?
  bed_id                  String?
  admission_date          DateTime?
  discharge_date          DateTime?
  chief_complaint         String?
  diagnosis               String?
  icd10_code              String?
  treatment_plan          String?
  discharge_summary       String?
  status                  String    @default("active")
  payment_type            PaymentType?
  bpjs_sep_number         String?
  insurance_policy_number String?
  satusehat_encounter_id  String?
  created_by              String?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  patients         patients     @relation(fields: [patient_id], references: [id])
  doctors          doctors?     @relation(fields: [doctor_id], references: [id])
  departments      departments? @relation(fields: [department_id], references: [id])
  beds             beds?        @relation(fields: [bed_id], references: [id])
  billings          billings[]
  medical_records   medical_records[]
  prescriptions     prescriptions[]
  lab_orders        lab_orders[]
  queue_entries     queue_entries[]
  patient_incidents patient_incidents[]
  vital_signs       vital_signs[]
  patient_consents  patient_consents[]

  @@index([patient_id])
  @@index([visit_date])
  @@index([department_id])
  @@index([doctor_id])
  @@index([bed_id])
  @@index([patient_id, visit_date, status])
}

model medical_records {
  id            String   @id @default(uuid())
  patient_id    String
  visit_id      String?
  record_date   DateTime @default(now())
  record_type   String?
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  vital_signs   Json?
  physical_exam Json?
  doctor_id     String?
  satusehat_condition_id   String?
  satusehat_observation_id String?
  created_by    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  patients   patients   @relation(fields: [patient_id], references: [id])
  visits     visits?    @relation(fields: [visit_id], references: [id])
  doctors    doctors?   @relation(fields: [doctor_id], references: [id])
  diagnoses  diagnoses[]

  @@index([patient_id])
  @@index([visit_id])
}

model diagnoses {
  id                String   @id @default(uuid())
  medical_record_id String?
  visit_id          String?
  patient_id        String?

  // ICD-11 fields (primary)
  icd11_code        String?
  icd11_entity_id   String?   // WHO Foundation URI
  icd11_title_en    String?
  icd11_title_id    String?

  // ICD-10 fields (backward compat / BPJS)
  icd10_code        String?
  icd10_title       String?

  diagnosis_type    String   @default("primer")  // primer | sekunder | komplikasi | komorbid
  is_confirmed      Boolean  @default(true)
  notes             String?
  created_by        String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  medical_records medical_records? @relation(fields: [medical_record_id], references: [id], onDelete: Cascade)

  @@index([medical_record_id])
  @@index([visit_id])
  @@index([icd11_code])
  @@index([icd10_code])
}

// ============================================
// PHARMACY
// ============================================

model medicines {
  id                    String   @id @default(uuid())
  medicine_code         String   @unique
  medicine_name         String
  generic_name          String?
  category              String?
  form                  String?
  strength              String?
  unit                  String
  manufacturer          String?
  selling_price         Decimal
  purchase_price        Decimal?
  min_stock             Int      @default(10)
  max_stock             Int      @default(1000)
  is_active             Boolean  @default(true)
  requires_prescription Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  medicine_batches           medicine_batches[]
  inventory_reorder_settings inventory_reorder_settings[]
  drug_interactions_a        drug_interactions[] @relation("InteractionA")
  drug_interactions_b        drug_interactions[] @relation("InteractionB")
  patient_drug_allergies     patient_drug_allergies[]
}

model medicine_batches {
  id             String   @id @default(uuid())
  medicine_id    String
  batch_number   String
  quantity       Int
  expiry_date    DateTime
  purchase_date  DateTime?
  purchase_price Decimal?
  supplier_id    String?
  location       String?
  status         String   @default("available")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  medicines medicines @relation(fields: [medicine_id], references: [id])

  @@index([medicine_id])
}

model prescriptions {
  id                  String    @id @default(uuid())
  prescription_number String    @unique
  patient_id          String
  visit_id            String?
  doctor_id           String?
  prescription_date   DateTime  @default(now())
  status              String    @default("pending")
  notes               String?
  // Dispensing workflow tracking
  verified_by         String?
  verified_at         DateTime?
  prepared_by         String?
  prepared_at         DateTime?
  dispensed_by        String?
  dispensed_at        DateTime?
  returned_by         String?
  returned_at         DateTime?
  rejection_reason    String?
  allergy_checked     Boolean   @default(false)
  allergy_warnings    Json      @default("[]")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  patients           patients           @relation(fields: [patient_id], references: [id])
  visits             visits?            @relation(fields: [visit_id], references: [id])
  doctors            doctors?           @relation(fields: [doctor_id], references: [id])
  prescription_items prescription_items[]

  @@index([patient_id])
  @@index([visit_id])
  @@index([patient_id, status, prescription_date])
}

model prescription_items {
  id                      String   @id @default(uuid())
  prescription_id         String
  medicine_id             String?
  medicine_name           String
  dosage                  String?
  frequency               String?
  duration                String?
  quantity                Int?
  unit                    String?
  instructions            String?
  dispensed_quantity      Int?
  dispensed_from_batches  Json     @default("[]")
  created_at              DateTime @default(now())

  prescriptions prescriptions @relation(fields: [prescription_id], references: [id])

  @@index([prescription_id])
}

// ============================================
// LABORATORY
// ============================================

model lab_orders {
  id           String   @id @default(uuid())
  order_number String   @unique
  patient_id   String
  visit_id     String?
  doctor_id    String?
  order_date   DateTime @default(now())
  priority     String   @default("normal")
  status       String   @default("pending")
  notes        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  patients    patients    @relation(fields: [patient_id], references: [id])
  visits      visits?     @relation(fields: [visit_id], references: [id])
  doctors     doctors?    @relation(fields: [doctor_id], references: [id])
  lab_results lab_results[]

  @@index([patient_id])
  @@index([visit_id])
  @@index([patient_id, status, order_date])
}

model lab_results {
  id                  String    @id @default(uuid())
  order_id            String
  test_code           String
  test_name           String
  result_value        String?
  unit                String?
  reference_range     String?
  flag                String?
  performed_by        String?
  verified_by         String?
  verified_at         DateTime?
  result_date         DateTime?
  notes               String?
  // Critical value tracking
  critical_alerted    Boolean   @default(false)
  critical_alert_at   DateTime?
  critical_alert_to   String?
  // Delta check
  delta_flag          Boolean   @default(false)
  previous_value      String?
  created_at          DateTime  @default(now())

  lab_orders lab_orders @relation(fields: [order_id], references: [id])

  @@unique([order_id, test_code])
  @@index([order_id])
}

model lab_reference_ranges {
  id            String    @id @default(uuid())
  test_code     String
  test_name     String
  gender        String    @default("all")
  age_min       Int?
  age_max       Int?
  normal_min    Decimal?
  normal_max    Decimal?
  critical_low  Decimal?
  critical_high Decimal?
  unit          String?
  created_at    DateTime  @default(now())

  @@unique([test_code, gender, age_min, age_max])
  @@index([test_code])
}

// ============================================
// BILLING
// ============================================

model billings {
  id             String        @id @default(uuid())
  invoice_number String        @unique
  patient_id     String
  visit_id       String
  billing_date   DateTime      @default(now())
  payment_type   PaymentType
  subtotal       Decimal       @default(0)
  discount       Decimal?
  tax            Decimal?
  total          Decimal       @default(0)
  paid_amount    Decimal?
  status         BillingStatus @default(pending)
  payment_method String?
  payment_date   DateTime?
  paid_by        String?
  notes          String?
  created_by     String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  patients      patients      @relation(fields: [patient_id], references: [id])
  visits        visits        @relation(fields: [visit_id], references: [id])
  billing_items billing_items[]

  @@index([patient_id])
  @@index([visit_id])
  @@index([patient_id, status, created_at])
}

model billing_items {
  id          String   @id @default(uuid())
  billing_id  String
  item_type   String
  item_name   String
  quantity    Int      @default(1)
  unit_price  Decimal
  total_price Decimal
  notes       String?
  created_at  DateTime @default(now())

  billings billings @relation(fields: [billing_id], references: [id])

  @@index([billing_id])
}

// ============================================
// BPJS
// ============================================

model bpjs_claims {
  id                 String      @id @default(uuid())
  claim_number       String      @unique
  patient_id         String
  visit_id           String
  sep_number         String
  claim_date         DateTime    @default(now())
  claim_amount       Decimal
  approved_amount    Decimal?
  status             ClaimStatus @default(draft)
  inacbg_code        String?
  inacbg_description String?
  submission_date    DateTime?
  verification_date  DateTime?
  rejection_reason   String?
  notes              String?
  created_by         String?
  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  @@index([patient_id])
  @@index([visit_id])
}

// ============================================
// SUPPLIERS & PURCHASE ORDERS
// ============================================

model suppliers {
  id             String   @id @default(uuid())
  supplier_code  String   @unique
  supplier_name  String
  contact_person String?
  phone          String?
  email          String?
  address        String?
  npwp           String?
  payment_terms  String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  purchase_orders purchase_orders[]
}

model purchase_orders {
  id                String    @id @default(uuid())
  po_number         String    @unique
  supplier_id       String
  order_date        DateTime  @default(now())
  expected_delivery DateTime?
  total_amount      Decimal
  status            String    @default("draft")
  submitted_at      DateTime?
  approved_by       String?
  approved_at       DateTime?
  received_at       DateTime?
  received_by       String?
  notes             String?
  created_by        String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  suppliers            suppliers              @relation(fields: [supplier_id], references: [id])
  purchase_order_items purchase_order_items[]

  @@index([supplier_id])
}

model purchase_order_items {
  id                String   @id @default(uuid())
  purchase_order_id String
  item_id           String
  quantity          Int
  unit_price        Decimal
  subtotal          Decimal
  received_quantity Int?
  created_at        DateTime @default(now())

  purchase_orders purchase_orders @relation(fields: [purchase_order_id], references: [id])

  @@index([purchase_order_id])
}

// ============================================
// HR
// ============================================

model employees {
  id              String    @id @default(uuid())
  user_id         String?
  employee_code   String    @unique
  full_name       String
  nik             String?
  birth_date      DateTime?
  gender          String?
  address         String?
  phone           String?
  email           String?
  department_id   String?
  position        String?
  employment_type String?
  join_date       DateTime?
  resign_date     DateTime?
  salary          Decimal?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  profiles        profiles?    @relation(fields: [user_id], references: [user_id])
  departments     departments? @relation(fields: [department_id], references: [id])
  attendance      attendance[]
  leave_requests  leave_requests[]
  payroll         payroll[]

  staff_certifications   staff_certifications[]
  notification_channels  notification_channels[]
  @@index([user_id])
  @@index([department_id])
}

model attendance {
  id              String   @id @default(uuid())
  employee_id     String
  attendance_date DateTime @db.Date
  check_in        DateTime?
  check_out       DateTime?
  status          String   @default("present")
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  employees employees @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, attendance_date])
  @@index([employee_id])
}

model leave_requests {
  id             String    @id @default(uuid())
  employee_id    String
  leave_type     String
  start_date     DateTime
  end_date       DateTime
  reason         String?
  status         String    @default("pending")
  approved_by    String?
  approved_at    DateTime?
  approval_notes String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  employees employees @relation(fields: [employee_id], references: [id])

  @@index([employee_id])
}

model payroll {
  id           String    @id @default(uuid())
  employee_id  String
  period_month Int
  period_year  Int
  base_salary  Decimal
  allowances   Decimal   @default(0)
  deductions   Decimal   @default(0)
  overtime     Decimal   @default(0)
  net_salary   Decimal
  status       String    @default("draft")
  paid_at      DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  employees employees @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, period_month, period_year])
  @@index([employee_id])
}

// ============================================
// DOCTOR SCHEDULES & WORK SHIFTS (HR)
// ============================================

model doctor_schedules {
  id            String    @id @default(uuid())
  doctor_id     String
  department_id String?
  day_of_week   Int
  start_time    String
  end_time      String
  quota         Int       @default(20)
  is_active     Boolean   @default(true)
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  doctor        doctors      @relation(fields: [doctor_id], references: [id], onDelete: Cascade)
  department    departments? @relation(fields: [department_id], references: [id])

  @@index([doctor_id])
  @@index([department_id])
}

model work_shifts {
  id            String    @id @default(uuid())
  shift_code    String    @unique
  shift_name    String
  start_time    String
  end_time      String
  is_overnight  Boolean   @default(false)
  department_id String?
  is_active     Boolean   @default(true)
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  department    departments? @relation(fields: [department_id], references: [id])

  @@index([department_id])
}

// ============================================
// APPOINTMENTS
// ============================================

model appointments {
  id               String   @id @default(uuid())
  patient_id       String
  doctor_id        String
  department_id    String?
  appointment_date DateTime @db.Date
  appointment_time String
  end_time         String?
  appointment_type String   @default("consultation")
  status           String   @default("scheduled")
  chief_complaint  String?
  notes            String?
  booking_source   String?
  reminder_sent    Boolean  @default(false)
  created_by       String?
  created_at       DateTime @default(now())
