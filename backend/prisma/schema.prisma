// ============================================
// SISRUTE REFERRALS
// ============================================

model sisrute_referrals {
  id                        String    @id @default(uuid())
  referral_number           String    @unique
  sisrute_id                String?
  patient_id                String?
  referral_type             String    @default("outgoing")
  referral_category         String?
  source_facility_code      String?
  source_facility_name      String?
  source_city               String?
  destination_facility_code String?
  destination_facility_name String?
  destination_city          String?
  destination_department    String?
  primary_diagnosis         String?
  diagnosis_description     String?
  reason_for_referral       String?
  clinical_summary          String?
  referring_doctor_name     String?
  transport_type            String?
  status                    String    @default("pending")
  sync_status               String    @default("pending")
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  patients patients? @relation(fields: [patient_id], references: [id])

  @@index([patient_id])
  @@index([status])
}

// ============================================
// INVENTORY REORDER SETTINGS
// ============================================

model inventory_reorder_settings {
  id                   String    @id @default(uuid())
  medicine_id          String?
  inventory_item_id    String?
  auto_reorder_enabled Boolean   @default(true)
  reorder_point        Int       @default(10)
  reorder_quantity     Int       @default(100)
  max_stock            Int?
  preferred_supplier   String?
  lead_time_days       Int       @default(7)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  medicines       medicines?       @relation(fields: [medicine_id], references: [id])
  inventory_items inventory_items? @relation(fields: [inventory_item_id], references: [id])

  @@index([medicine_id])
  @@index([inventory_item_id])
}

// ============================================
// INACBG CALCULATION HISTORY
// ============================================

model inacbg_calculation_history {
  id                  String    @id @default(uuid())
  drg_code            String?
  drg_description     String?
  severity_level      Int       @default(1)
  los_actual          Int?
  los_grouper         Int?
  primary_diagnosis   String?
  secondary_diagnoses Json      @default("[]")
  procedures          Json      @default("[]")
  base_tariff         Decimal?
  adjustment_factor   Decimal?
  final_tariff        Decimal?
  hospital_cost       Decimal?
  variance            Decimal?
  calculated_by       String?
  calculated_at       DateTime  @default(now())
}

// ============================================
// DRG CODES (INADRG / INACBG Reference)
// ============================================

model drg_codes {
  id              String    @id @default(uuid())
  drg_code        String    @unique
  drg_name        String
  severity_level  Int       @default(1)
  national_tariff Decimal   @default(0)
  created_at      DateTime  @default(now())
}

// ============================================
// REFRESH TOKENS (DB-backed rotation)
// ============================================

model refresh_tokens {
  id             String    @id @default(uuid())
  user_id        String
  token_hash     String    @unique
  expires_at     DateTime
  created_at     DateTime  @default(now())
  revoked_at     DateTime?
  revoked_reason String?
  user_agent     String?
  ip_address     String?

  @@index([user_id, expires_at])
  @@index([token_hash])
}

// ============================================
// BILLING RULES (Rule Engine)
// ============================================

model billing_rules {
  id            String    @id @default(uuid())
  rule_name     String
  rule_type     String                // tariff | discount | tax
  payment_type  String?               // bpjs | cash | insurance | corporate | null = all
  visit_type    String?               // outpatient | inpatient | emergency | null = all
  department_id String?
  item_type     String?               // konsultasi | lab | radiologi | obat | tindakan | kamar | null = all
  amount        Decimal   @default(0)
  amount_type   String    @default("fixed")  // fixed | percent
  priority      Int       @default(10)
  is_active     Boolean   @default(true)
  description   String?
  created_by    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  departments   departments? @relation(fields: [department_id], references: [id])

  @@index([is_active, rule_type, payment_type])
}


// ============================================
// BACKGROUND JOBS (Phase 3)
// ============================================

model background_jobs {
  id            String    @id @default(uuid())
  queue_name    String
  job_name      String
  status        String    @default("pending")
  payload       Json      @default("{}")
  result        Json?
  error_message String?
  attempts      Int       @default(0)
  max_attempts  Int       @default(3)
  priority      Int       @default(5)
  scheduled_at  DateTime  @default(now())
  started_at    DateTime?
  completed_at  DateTime?
  created_by    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([queue_name, status, scheduled_at])
  @@index([status, priority, scheduled_at])
}

// ============================================
// SCHEDULED REPORTS (Phase 3)
// ============================================

model scheduled_reports {
  id            String    @id @default(uuid())
  report_type   String
  report_period String
  status        String    @default("pending")
  data          Json?
  file_url      String?
  generated_at  DateTime?
  error_message String?
  created_at    DateTime  @default(now())

  @@index([report_type, report_period])
}

// ============================================
// ANALYTICS SNAPSHOTS (Phase 3)
// ============================================

model analytics_snapshots {
  id              String    @id @default(uuid())
  snapshot_type   String
  snapshot_date   DateTime  @db.Date
  department_id   String?
  data            Json
  computed_at     DateTime  @default(now())

  departments     departments? @relation(fields: [department_id], references: [id])

  @@unique([snapshot_type, snapshot_date, department_id])
  @@index([snapshot_type, snapshot_date])
}

// ============================================
// PACS / DICOM (Phase 3)
// ============================================

model pacs_configs {
  id               String   @id @default(uuid())
  aet_title        String
  host             String
  port             Int      @default(11112)
  wado_rs_url      String?
  stow_rs_url      String?
  qido_rs_url      String?
  wado_uri_url     String?
  auth_type        String   @default("none")
  auth_credentials Json?
  is_active        Boolean  @default(true)
  description      String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  dicom_studies    dicom_studies[]
}

model dicom_studies {
  id                 String   @id @default(uuid())
  study_instance_uid String   @unique
  radiology_order_id String?
  patient_id         String?
  accession_number   String?
  study_date         DateTime? @db.Date
  study_time         String?
  study_description  String?
  modality           String?
  referring_physician String?
  institution_name   String?
  num_series         Int      @default(0)
  num_instances      Int      @default(0)
  total_size_bytes   BigInt   @default(0)
  retrieve_url       String?
  status             String   @default("pending")
  pacs_config_id     String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  patients           patients?         @relation(fields: [patient_id], references: [id])
  pacs_configs       pacs_configs?     @relation(fields: [pacs_config_id], references: [id])
  dicom_series       dicom_series[]

  @@index([patient_id, study_date])
  @@index([accession_number])
}

model dicom_series {
  id                  String   @id @default(uuid())
  study_id            String
  series_instance_uid String   @unique
  series_number       Int?
  series_description  String?
  modality            String?
  body_part_examined  String?
  num_instances       Int      @default(0)
  retrieve_url        String?
  created_at          DateTime @default(now())

  dicom_studies       dicom_studies     @relation(fields: [study_id], references: [id], onDelete: Cascade)
  dicom_instances     dicom_instances[]

  @@index([study_id])
}

model dicom_instances {
  id                 String   @id @default(uuid())
  series_id          String
  sop_instance_uid   String   @unique
  sop_class_uid      String?
  instance_number    Int?
  rows               Int?
  columns            Int?
  bits_allocated     Int?
  retrieve_url       String?
  thumbnail_url      String?
  created_at         DateTime @default(now())

  dicom_series       dicom_series @relation(fields: [series_id], references: [id], onDelete: Cascade)

  @@index([series_id])
}

model dicom_worklist {
  id                 String    @id @default(uuid())
  radiology_order_id String?
  patient_id         String?
  accession_number   String    @unique
  scheduled_station  String?
  scheduled_modality String?
  scheduled_datetime DateTime?
  procedure_code     String?
  procedure_desc     String?
  requested_physician String?
  worklist_status    String    @default("scheduled")
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  patients           patients? @relation(fields: [patient_id], references: [id])

  @@index([worklist_status, scheduled_datetime])
  @@index([patient_id])
}

// ============================================
// DRUG INTERACTIONS (Phase 4)
// ============================================

model drug_interactions {
  id              String   @id @default(uuid())
  medicine_id_a   String
  medicine_id_b   String
  severity        String   @default("moderate")
  description     String
  mechanism       String?
  clinical_effect String?
  management      String?
  source          String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  medicine_a      medicines @relation("InteractionA", fields: [medicine_id_a], references: [id], onDelete: Cascade)
  medicine_b      medicines @relation("InteractionB", fields: [medicine_id_b], references: [id], onDelete: Cascade)

  @@unique([medicine_id_a, medicine_id_b])
  @@index([medicine_id_a])
  @@index([medicine_id_b])
}

model patient_drug_allergies {
  id            String   @id @default(uuid())
  patient_id    String
  medicine_id   String?
  allergen_name String
  reaction_type String?
  severity      String   @default("moderate")
  notes         String?
  reported_by   String?
  reported_at   DateTime @default(now())
  is_active     Boolean  @default(true)

  patients      patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  medicines     medicines? @relation(fields: [medicine_id], references: [id], onDelete: SetNull)

  @@index([patient_id])
}

// ============================================
// STR / SIP TRACKING (Phase 4)
// ============================================

model staff_certifications {
  id              String   @id @default(uuid())
  employee_id     String?
  user_id         String?
  cert_type       String
  cert_number     String
  issuer          String?
  issue_date      DateTime? @db.Date
  expiry_date     DateTime  @db.Date
  status          String   @default("active")
  document_url    String?
  notes           String?
  alert_sent_30d  Boolean  @default(false)
  alert_sent_7d   Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  employees       employees? @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([expiry_date, status])
  @@index([employee_id])
}

// ============================================
// ASPAK ASSETS (Phase 4)
// ============================================

model aspak_assets {
  id                  String   @id @default(uuid())
  asset_code          String?  @unique
  asset_name          String
  asset_category      String?
  asset_type          String?
  brand               String?
  model               String?
  serial_number       String?
  year_of_purchase    Int?
  purchase_price      Decimal? @db.Decimal(15,2)
  current_condition   String   @default("baik")
  department_id       String?
  room_location       String?
  quantity            Int      @default(1)
  unit                String   @default("unit")
  last_maintenance_at DateTime? @db.Date
  next_maintenance_at DateTime? @db.Date
  kemenkes_code       String?
  is_active           Boolean  @default(true)
  notes               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  departments         departments? @relation(fields: [department_id], references: [id])

  @@index([department_id])
  @@index([asset_category])
}

model aspak_reports {
  id            String    @id @default(uuid())
  report_period String
  report_type   String    @default("monthly")
  status        String    @default("draft")
  submitted_at  DateTime?
  submitted_by  String?
  kemenkes_ref  String?
  data_snapshot Json?
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
}

// ============================================
// INSIDEN KESELAMATAN PASIEN / IKP (Phase 4)
// ============================================

model patient_incidents {
  id                   String    @id @default(uuid())
  incident_code        String?   @unique
  patient_id           String?
  visit_id             String?
  department_id        String?
  incident_date        DateTime
  incident_type        String
  incident_category    String?
  description          String
  immediate_action     String?
  contributing_factors String?
  severity_grade       String    @default("2")
  harm_to_patient      String    @default("tidak_ada")
  status               String    @default("draft")
  reported_by          String?
  reporter_role        String?
  investigator_id      String?
  investigation_notes  String?
  corrective_action    String?
  prevention_plan      String?
  closed_at            DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  patients             patients?     @relation(fields: [patient_id], references: [id])
  visits               visits?       @relation(fields: [visit_id], references: [id])
  departments          departments?  @relation(fields: [department_id], references: [id])

  @@index([incident_date])
  @@index([department_id, incident_date])
  @@index([status])
}

// ============================================
// E-CONSENT DIGITAL (Phase 4)
// ============================================

model patient_consents {
  id                  String    @id @default(uuid())
  patient_id          String
  visit_id            String?
  consent_type        String
  consent_text        String
  language            String    @default("id")
  status              String    @default("pending")
  signed_by_name      String?
  signed_by_relation  String?
  signed_at           DateTime?
  signed_ip           String?
  signature_hash      String?
  signature_data      String?
  witness_name        String?
  witness_role        String?
  valid_until         DateTime?
  document_url        String?
  revoked_at          DateTime?
  revoked_reason      String?
  created_by          String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  patients            patients  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  visits              visits?   @relation(fields: [visit_id], references: [id])

  @@index([patient_id, consent_type])
  @@index([visit_id])
}

// ============================================
// NOTIFICATION CHANNELS & LOGS (Phase 4)
// ============================================

model notification_channels {
  id            String    @id @default(uuid())
  patient_id    String?
  employee_id   String?
  channel_type  String
  address       String
  address_hash  String?
  is_verified   Boolean   @default(false)
  is_active     Boolean   @default(true)
  opt_in_at     DateTime?
  opt_out_at    DateTime?
  created_at    DateTime  @default(now())

  patients      patients?  @relation(fields: [patient_id], references: [id])
  employees     employees? @relation(fields: [employee_id], references: [id])

  @@index([patient_id])
  @@index([address_hash])
}

model notification_logs {
  id              String    @id @default(uuid())
  channel_type    String
  recipient       String
  template_type   String
  payload         Json      @default("{}")
  status          String    @default("pending")
  provider        String?
  provider_msg_id String?
  error_message   String?
  sent_at         DateTime?
  created_at      DateTime  @default(now())

  @@index([status, created_at])
}

// ============================================
// VITAL SIGNS TIME-SERIES (Phase 4)
// ============================================

model vital_signs {
  id               String   @id @default(uuid())
  patient_id       String
  visit_id         String?
  recorded_by      String?
  recorded_at      DateTime @default(now())
  systolic_bp      Int?
  diastolic_bp     Int?
  heart_rate       Int?
  respiratory_rate Int?
  spo2             Decimal? @db.Decimal(5,2)
  temperature      Decimal? @db.Decimal(5,2)
  temp_route       String?
  weight_kg        Decimal? @db.Decimal(6,2)
  height_cm        Decimal? @db.Decimal(6,2)
  bmi              Decimal? @db.Decimal(5,2)
  pain_score       Int?
  gcs_total        Int?
  gcs_eye          Int?
  gcs_verbal       Int?
  gcs_motor        Int?
  blood_glucose    Decimal? @db.Decimal(6,2)
  notes            String?
  source           String   @default("manual")

  patients         patients @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  visits           visits?  @relation(fields: [visit_id], references: [id])

  @@index([patient_id, recorded_at])
  @@index([visit_id, recorded_at])
}
