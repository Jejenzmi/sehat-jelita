  status            String    @default("available")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  inventory_items        inventory_items         @relation(fields: [item_id], references: [id])
  inventory_transactions inventory_transactions[]

  @@index([item_id])
}

model inventory_transactions {
  id               String   @id @default(uuid())
  item_id          String
  batch_id         String?
  transaction_type String
  quantity         Int
  reason           String?
  reference_id     String?
  reference_type   String?
  performed_by     String?
  created_at       DateTime @default(now())

  inventory_items   inventory_items    @relation(fields: [item_id], references: [id])
  inventory_batches inventory_batches? @relation(fields: [batch_id], references: [id])

  @@index([item_id])
}

// ============================================
// EDUCATION / MEDICAL TRAINING
// ============================================

model medical_trainees {
  id                    String    @id @default(uuid())
  trainee_code          String    @unique
  full_name             String
  trainee_type          String?
  institution           String?
  department_id         String?
  start_date            DateTime?
  end_date              DateTime?
  primary_supervisor_id String?
  status                String    @default("active")
  created_by            String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  clinical_rotations    clinical_rotations[]
  activity_registrations activity_registrations[]
}

model clinical_rotations {
  id             String    @id @default(uuid())
  trainee_id     String
  department_id  String?
  supervisor_id  String?
  start_date     DateTime
  end_date       DateTime
  rotation_type  String?
  status         String    @default("scheduled")
  evaluation     String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  medical_trainees medical_trainees @relation(fields: [trainee_id], references: [id])

  @@index([trainee_id])
}

model academic_activities {
  id              String    @id @default(uuid())
  activity_code   String    @unique
  title           String
  activity_type   String?
  description     String?
  scheduled_date  DateTime?
  location        String?
  organizer_id    String?
  max_participants Int?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  activity_registrations activity_registrations[]
}

model activity_registrations {
  id          String    @id @default(uuid())
  activity_id String
  trainee_id  String
  registered_at DateTime @default(now())
  status      String    @default("registered")
  attendance  Boolean?
  score       Decimal?
  notes       String?
  created_at  DateTime  @default(now())

  academic_activities academic_activities @relation(fields: [activity_id], references: [id])
  medical_trainees    medical_trainees    @relation(fields: [trainee_id], references: [id])

  @@unique([activity_id, trainee_id])
  @@index([trainee_id])
}

model research_projects {
  id              String    @id @default(uuid())
  project_code    String    @unique
  title           String
  description     String?
  principal_investigator_id String?
  start_date      DateTime?
  end_date        DateTime?
  status          String    @default("planning")
  budget          Decimal?
  funding_source  String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

// ============================================
// HR - TRAININGS
// ============================================

model trainings {
  id              String    @id @default(uuid())
  training_name   String
  training_type   String?
  description     String?
  trainer         String?
  scheduled_date  DateTime?
  duration_hours  Int?
  location        String?
  max_participants Int?
  status          String    @default("planned")
  created_by      String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}
