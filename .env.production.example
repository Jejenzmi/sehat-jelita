# ============================================
# SIMRS ZEN - Production Environment Variables
# Copy this file to .env and fill in ALL values
# NEVER commit .env to version control
# ============================================

# ---- Database ----
DB_USER=simrs
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=simrs_zen
# For Docker Compose use 'postgres' as host; for standalone use 'localhost'
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# ---- Redis ----
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
# For Docker Compose use 'redis' as host; for standalone use 'localhost'
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ---- JWT ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- Server ----
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://yourdomain.com

# ---- Frontend (Vite build args) ----
VITE_API_MODE=nodejs
VITE_API_URL=/api

# ---- Docker image registry (for docker-compose.prod.yml) ----
REGISTRY=ghcr.io
IMAGE_NAMESPACE=jejenzmi/sehat-jelita
IMAGE_TAG=latest

# ---- BPJS Integration (optional) ----
BPJS_CONS_ID=
BPJS_SECRET_KEY=
BPJS_USER_KEY=
BPJS_BASE_URL=https://apijkn.bpjs-kesehatan.go.id

# ---- SatuSehat Integration (optional) ----
SATUSEHAT_CLIENT_ID=
SATUSEHAT_CLIENT_SECRET=
SATUSEHAT_ORGANIZATION_ID=
SATUSEHAT_BASE_URL=https://api-satusehat.kemkes.go.id
