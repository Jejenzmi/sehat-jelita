# ============================================================
# SIMRS ZEN - Production Environment Variables
# Copy to .env and fill in ALL values before deploying
# JANGAN commit file .env ke version control!
# ============================================================

# ----------------------------------------
# Application
# ----------------------------------------
NODE_ENV=production
PORT=3000

# ----------------------------------------
# Database (PostgreSQL)
# ----------------------------------------
DB_USER=simrs
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=simrs_zen
# For Docker Compose use 'postgres' as host; for standalone use 'localhost'
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# ----------------------------------------
# Redis
# ----------------------------------------
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
# For Docker Compose use 'redis' as host; for standalone use 'localhost'
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ----------------------------------------
# JWT Authentication
# ----------------------------------------
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ----------------------------------------
# Frontend URL (untuk CORS dan cookie)
# ----------------------------------------
FRONTEND_URL=https://yourdomain.com

# ----------------------------------------
# Docker Image Registry (untuk docker-compose.prod.yml)
# ----------------------------------------
# Images are published to GHCR by the docker-build.yml workflow.
# For Docker Manager to pull them without authentication the GHCR packages
# must be set to public.  The workflow sets visibility automatically if you
# add a repository secret named GH_PAT (a Personal Access Token with the
# write:packages scope).  Without GH_PAT the workflow falls back to
# GITHUB_TOKEN which may also work for repository-linked packages.
# Alternatively, set package visibility to public manually in GitHub:
#   https://github.com/users/jejenzmi/packages
REGISTRY=ghcr.io
IMAGE_NAMESPACE=jejenzmi/sehat-jelita
IMAGE_TAG=latest

# ----------------------------------------
# BPJS Integration (opsional)
# ----------------------------------------
BPJS_CONS_ID=
BPJS_SECRET_KEY=
BPJS_USER_KEY=
BPJS_BASE_URL=https://apijkn.bpjs-kesehatan.go.id/vclaim-rest

# ----------------------------------------
# SatuSehat Integration (opsional)
# ----------------------------------------
SATUSEHAT_CLIENT_ID=
SATUSEHAT_CLIENT_SECRET=
SATUSEHAT_ORGANIZATION_ID=
SATUSEHAT_BASE_URL=https://api-satusehat.kemkes.go.id

# ----------------------------------------
# Frontend Vite Variables
# ----------------------------------------
VITE_API_MODE=nodejs
VITE_API_URL=/api
