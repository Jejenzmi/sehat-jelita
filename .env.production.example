# ============================================
# SIMRS ZEN - Production Environment Variables
# Copy to .env.production and fill in values
# NEVER commit this file with real values
# ============================================

# Application
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-domain.com

# ============================================
# Database (PostgreSQL) - REQUIRED
# ============================================
DB_USER=simrs
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=simrs_zen
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# ============================================
# Redis - REQUIRED
# ============================================
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ============================================
# JWT Authentication - REQUIRED
# Generate: openssl rand -base64 64
# ============================================
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTER_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Frontend (Vite)
# ============================================
VITE_API_MODE=nodejs
VITE_API_URL=/api

# ============================================
# BPJS Integration
# ============================================
BPJS_CONS_ID=
BPJS_SECRET_KEY=
BPJS_USER_KEY=
BPJS_BASE_URL=https://apijkn.bpjs-kesehatan.go.id
BPJS_VCLAIM_URL=https://apijkn.bpjs-kesehatan.go.id/vclaim-rest
BPJS_APLICARE_URL=https://apijkn.bpjs-kesehatan.go.id/aplicaresws

# ============================================
# SATU SEHAT Integration
# ============================================
SATUSEHAT_AUTH_URL=https://api-satusehat.dto.kemkes.go.id/oauth2/v1
SATUSEHAT_BASE_URL=https://api-satusehat.dto.kemkes.go.id/fhir-r4/v1
SATUSEHAT_CLIENT_ID=
SATUSEHAT_CLIENT_SECRET=
SATUSEHAT_ORGANIZATION_ID=
# Aliases used by some backend services (kept for compatibility with docker-compose.yml)
SATU_SEHAT_CLIENT_ID=
SATU_SEHAT_CLIENT_SECRET=
SATU_SEHAT_ORG_ID=
SATU_SEHAT_ENV=production

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SIMRS ZEN <noreply@your-domain.com>

# ============================================
# Logging
# ============================================
LOG_LEVEL=warn
LOG_FORMAT=json

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS
# ============================================
CORS_ORIGIN=https://your-domain.com
