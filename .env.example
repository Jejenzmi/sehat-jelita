# ============================================
# SIMRS ZEN - Frontend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# API Mode: 'supabase' (Lovable Cloud) or 'nodejs' (local PostgreSQL)
VITE_API_MODE=nodejs

# Local Node.js Backend URL (used when VITE_API_MODE=nodejs)
VITE_API_URL=http://localhost:3000/api

# ============================================
# Supabase (only needed when VITE_API_MODE=supabase)
# ============================================
# VITE_SUPABASE_PROJECT_ID=your-project-id
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# VITE_SUPABASE_URL=https://your-project.supabase.co
