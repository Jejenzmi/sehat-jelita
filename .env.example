# ============================================
# SIMRS ZEN - Frontend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# API Mode: nodejs (Node.js/Express backend)
VITE_API_MODE=nodejs

# Backend URL - use /api to proxy through nginx/vite-dev-proxy (recommended)
VITE_API_URL=/api

# Alternatively, point directly to the backend server:
# VITE_API_URL=http://localhost:3000/api
