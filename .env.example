# ============================================
# SIMRS ZEN - Frontend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# API Mode: nodejs (Node.js/Express backend)
VITE_API_MODE=nodejs

# Node.js Backend URL
VITE_API_URL=http://localhost:3000/api

# Production Backend URL (cloud hosting - simrszen.id)
# VITE_API_URL=https://simrszen.id/api
